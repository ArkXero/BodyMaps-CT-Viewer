# bundle: imports provided BodyMaps CT + precomputed masks
# suprem: runs linked qchen99/suprem:v1 Docker prototype on NVIDIA GPU host
# external: invokes BODYMAPS_INFERENCE_COMMAND
BODYMAPS_ADAPTER=bundle
BODYMAPS_ARTIFACTS_DIR=artifacts
BODYMAPS_MAX_UPLOAD_MB=512
BODYMAPS_INFERENCE_TIMEOUT_SECONDS=3600
BODYMAPS_SAMPLE_CT=/absolute/path/to/BDMAP_00000338.zip
# BODYMAPS_SUPREM_IMAGE=qchen99/suprem:v1

# External prototype contract. Both placeholders are required.
# Command must write result.json, volume.npy, mask.npy, and labels.json.
# BODYMAPS_INFERENCE_COMMAND=python /path/to/prototype/inference.py --input {input} --output-dir {output_dir}
# BODYMAPS_PROTOTYPE_PATH=/path/to/prototype
# BODYMAPS_WEIGHTS_PATH=/path/to/checkpoint.pth
